<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GATARAD STUDIO | Creative Excellence</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #0f0f0f; color: #ffffff; }
        .gradient-text {
            background: linear-gradient(90deg, #ff8a00, #e52e71);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>
<body>

    <nav class="flex justify-between items-center p-6 max-w-7xl mx-auto">
        <div class="text-2xl font-black tracking-tighter uppercase">
            Gatarad<span class="text-orange-500">Studio</span>
        </div>
        <div class="space-x-8 hidden md:block font-medium">
            <a href="#work" class="hover:text-orange-500 transition">Work</a>
            <a href="#services" class="hover:text-orange-500 transition">Services</a>
            <a href="#contact" class="px-5 py-2 bg-white text-black rounded-full font-bold hover:bg-orange-500 hover:text-white transition">Hire Us</a>
        </div>
    </nav>

    <header class="py-20 px-6 text-center max-w-4xl mx-auto">
        <h1 class="text-6xl md:text-8xl font-black mb-6">
            WE CREATE <span class="gradient-text">LEGENDS.</span>
        </h1>
        <p class="text-gray-400 text-lg md:text-xl mb-10">
            Gatarad Studio is a premier creative powerhouse specializing in digital storytelling, brand identity, and high-end visual design.
        </p>
        <div class="flex flex-col md:flex-row justify-center gap-4">
            <button class="bg-orange-600 hover:bg-orange-700 text-white px-8 py-4 rounded-lg font-bold text-lg transition">View Portfolio</button>
            <button class="border border-gray-700 hover:bg-gray-800 text-white px-8 py-4 rounded-lg font-bold text-lg transition">Our Process</button>
        </div>
    </header>

    <section id="services" class="py-20 bg-[#161616]">
        <div class="max-w-7xl mx-auto px-6">
            <h2 class="text-3xl font-bold mb-12">Our Expertise</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="p-8 border border-gray-800 rounded-2xl hover:border-orange-500 transition group">
                    <i class="fa-solid fa-camera-retro text-4xl mb-6 text-orange-500"></i>
                    <h3 class="text-xl font-bold mb-4">Photography</h3>
                    <p class="text-gray-400">Capturing moments that tell a story beyond words. High-end editing and production.</p>
                </div>
                <div class="p-8 border border-gray-800 rounded-2xl hover:border-orange-500 transition group">
                    <i class="fa-solid fa-pen-nib text-4xl mb-6 text-orange-500"></i>
                    <h3 class="text-xl font-bold mb-4">Brand Identity</h3>
                    <p class="text-gray-400">Designing logos and visual languages that make your brand unforgettable.</p>
                </div>
                <div class="p-8 border border-gray-800 rounded-2xl hover:border-orange-500 transition group">
                    <i class="fa-solid fa-clapperboard text-4xl mb-6 text-orange-500"></i>
                    <h3 class="text-xl font-bold mb-4">Motion Graphics</h3>
                    <p class="text-bold text-gray-400">Bringing static designs to life with cinematic animation and transitions.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="py-24 text-center">
        <h2 class="text-4xl font-bold mb-6">Have a project in mind?</h2>
        <p class="text-gray-400 mb-8">Let’s build something extraordinary together.</p>
        <a href="mailto:hello@gatarad.studio" class="text-3xl font-black underline hover:text-orange-500 transition">
            hello@gatarad.studio
        </a>
    </section>

    <footer class="p-10 border-t border-gray-900 text-center text-gray-500 text-sm">
        &copy; 2026 GATARAD STUDIO. All Rights Reserved.
    </footer>

</body>
</html>
